<UserControl x:Class="Betrian.CflmNavi.App.Views.StageTabUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views"
             xmlns:modes="clr-namespace:Betrian.CflmNavi.App.Views.Modes"
             xmlns:views="clr-namespace:Betrian.CflmNavi.App.Views"
             mc:Ignorable="d" >
    <Grid>
        <StackPanel Orientation="Vertical">
            <views:OverViewImageUserControl DataContext="{Binding OverviewImageVM}"/>
            <Separator Grid.Row="3" Margin="5,10"/>
            <modes:StageOverviewUserControl DataContext="{Binding StageOverview}"/>
        </StackPanel>
    </Grid>
</UserControl>
