<UserControl x:Class="Betrian.CflmNavi.App.Views.Projects.ProjectManagerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:viewModels="clr-namespace:Betrian.CflmNavi.App.ViewModels.Projects"
             xmlns:projects="clr-namespace:CFLMnavi.Projects;assembly=CFLMnavi.Projects"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewModels:ProjectManagerDialogViewModel}">
    <StackPanel>

        <TextBlock Text="Projects" FontSize="25" FontWeight="SemiBold" Foreground="{StaticResource ForegroundLightBrush}"/>

        <Grid VerticalAlignment="Center" Margin="0,40,0,0">
            <TextBox HorizontalAlignment="Left" Width="150" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="12" FontWeight="SemiBold" VerticalContentAlignment="Center" x:Name="SearchField"/>
            <Label Content="SEARCH" IsHitTestVisible="False" Padding="6 2 0 0" VerticalAlignment="Center" FontWeight="Bold">
                <Label.Style>
                    <Style TargetType="{x:Type Label}">
                        <Setter Property="Visibility" Value="Hidden"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ElementName=SearchField, Path=Text}" Value=""/>
                                    <Condition Binding="{Binding ElementName=SearchField, Path=IsFocused}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>
            <Button Content="+ NEW PROJECT"
                    HorizontalAlignment="Right"
                    Width="150" FontWeight="SemiBold" FontSize="12"
                    Command="{Binding CreateNewProjectCommand}"/>
        </Grid>

        <Border HorizontalAlignment="Stretch" VerticalAlignment="Top"
                Margin="0,20,0,0"  CornerRadius="5" Padding="20,15"
                Background="{StaticResource BackgroundLightBrush}">
            <TextBlock Text="Recent projects" Foreground="{StaticResource ForegroundLightBrush}" FontWeight="SemiBold" FontSize="20"/>
        </Border>

        <HeaderedItemsControl x:Name="ProjectItemsControl" ItemsSource="{Binding Projects}" Margin="0,20,0,0">
            <HeaderedItemsControl.Template>
                <ControlTemplate TargetType="{x:Type HeaderedItemsControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <ContentPresenter ContentSource="Header"/>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="233" >
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Grid>
                </ControlTemplate>
            </HeaderedItemsControl.Template>
            <HeaderedItemsControl.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="20,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name"/>
                        <TextBlock Grid.Column="1" Text="Created"/>
                        <TextBlock Grid.Column="2" Text="Modified"/>
                        <TextBlock Grid.Column="3" Text="Description"/>
                    </Grid>
                </DataTemplate>
            </HeaderedItemsControl.HeaderTemplate>
            <HeaderedItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type projects:ProjectDescriptor}">
                    <Button Width="Auto"
                            Command="{Binding DataContext.SelectProjectCommand, ElementName=ProjectItemsControl}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border BorderThickness="1" Padding="20,10" IsHitTestVisible="True">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="BorderBrush" Value="{StaticResource BackgroundBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource HighlightMutedBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TimeOfCreation, StringFormat=d}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding TimeOfAccess, StringFormat=d}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Description}"
                                       VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            <Button Grid.Column="4" Padding="3" Width="NaN" Height="25" Style="{StaticResource FlatButtonStyle}" ToolTip="Delete"
                                    Command="{Binding DataContext.DeleteProjectCommand, ElementName=ProjectItemsControl}" CommandParameter="{Binding}">
                                <Image Source="{StaticResource icon_trash}" />
                            </Button>
                        </Grid>
                    </Button>
                </DataTemplate>
            </HeaderedItemsControl.ItemTemplate>
        </HeaderedItemsControl>

        <Button Grid.Row="4" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0 5"
                Command="{Binding SwitchProjectsShownCommand}">
            <Button.Style>
                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource FlatButtonStyle}">
                    <Setter Property="Content" Value="SHOW ALL"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShownProjects}" Value="{x:Static viewModels:ShownProjects.All}">
                            <Setter Property="Content" Value="SHOW RECENT"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </StackPanel>
</UserControl>
