<UserControl x:Class="Betrian.CflmNavi.App.Views.Projects.CreateNewProjectUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views.Projects"
             xmlns:styles="clr-namespace:Betrian.WPF.CeitecStyles.Controls;assembly=Betrian.WPF.CeitecStyles"
             xmlns:viewModels="clr-namespace:Betrian.CflmNavi.App.ViewModels.Projects"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance Type=viewModels:CreateNewProjectDialogViewModel}">
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding CreateProjectCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="New Project" Foreground="{StaticResource ForegroundLightBrush}"
                       FontSize="25" FontWeight="SemiBold"/>

            <TextBlock Text="Project name*" Margin="0,40,0,0"/>
            <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MaxLength="255" />

            <TextBlock Text="Project description" Margin="0,20,0,0"/>
            <TextBox Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True" Height="100" Width="Auto"/>

            <TextBlock Text="Pretilt settings" Margin="0,20,0,0"/>
            <!-- ListBox used since it implements the IsSelected property on its items. -->
            <ListBox ItemsSource="{Binding PretiltSettings}"
                 SelectedItem="{Binding SelectedPretiltSetting}" SelectionMode="Single"
                 BorderBrush="Transparent" Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <!-- Remove the default style -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:PretiltViewModel}">
                        <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=TwoWay}"
                                 VerticalContentAlignment="Center" Margin="0,5">
                            <TextBlock>
                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                <Run Text="{Binding Tilt, StringFormat=({0:N0}°), Mode=OneWay}"/>
                            </TextBlock>
                        </RadioButton>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        <Button Grid.Row="1" Content="START NEW PROJECT" HorizontalAlignment="Center" Width="200"
                Command="{Binding CreateProjectCommand}"/>
    </Grid>
</UserControl>
