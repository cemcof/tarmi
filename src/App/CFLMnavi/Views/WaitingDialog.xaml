<bwpf:DarkWindow x:Class="Betrian.CflmNavi.App.Views.WaitingDialog"
                 x:TypeArguments="viewModels:WaitingDialogViewModel"
                 xmlns:viewModels="clr-namespace:Betrian.CflmNavi.App.ViewModels"
                 xmlns:bwpf="clr-namespace:Betrian.WPF;assembly=Betrian.WPF"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views"
                 xmlns:converters="clr-namespace:Betrian.CflmNavi.App.Converters"
                 mc:Ignorable="d"
                 WindowStyle="None"
                 AllowsTransparency="True"
                 Background="Transparent"
                 Topmost="True"
                 WindowStartupLocation="CenterOwner"
                 SizeToContent="WidthAndHeight"
                 d:DataContext="{d:DesignInstance Type={x:Type viewModels:WaitingDialogViewModel}}">
    <Border CornerRadius="10"
            Background="{StaticResource BackgroundBrush}" Opacity="0.7" Padding="20 15">
        <Grid>
            <Grid.Resources>
                <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
                <converters:ChainedValueConverter x:Key="InversedBooleanToVisibilityConverter">
                    <converters:BooleanInverseConverter/>
                    <BooleanToVisibilityConverter/>
                </converters:ChainedValueConverter>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}" FontSize="20" Foreground="{StaticResource ForegroundLightBrush}" Margin="0 0 0 5"/>
            <TextBlock Grid.Row="1" Text="{Binding Text}" Margin="0 0 0 5"/>
            <ProgressBar Grid.Row="2" Value="{Binding Progress.Percent, Mode=OneWay}" Width="300" Height="18" VerticalAlignment="Center" IsIndeterminate="{Binding IsIndeterminate}"
                        Foreground="{StaticResource HighlightBrush}" Background="{StaticResource BackgroundLightBrush}" BorderBrush="{StaticResource BackgroundDarkBrush}"/>
            <TextBlock  Grid.Row="2" Background="Transparent" Foreground="{StaticResource ForegroundLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Text="{Binding Progress.Percent, Mode=OneWay, StringFormat={}{0:N0} %}" Visibility="{Binding IsIndeterminate, Converter={StaticResource InversedBooleanToVisibilityConverter}}"/>
            <Button Grid.Row="2" Grid.Column="1" Content="{Binding TerminateControlName}" Command="{Binding TerminateCommand}" Margin="10 0 0 0" Visibility="{Binding IsTerminatable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </Border>
</bwpf:DarkWindow>
