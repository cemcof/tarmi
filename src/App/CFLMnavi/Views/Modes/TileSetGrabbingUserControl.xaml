<UserControl x:Class="Betrian.CflmNavi.App.Views.Modes.TileSetGrabbingUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views.Modes"
             xmlns:controls="clr-namespace:Betrian.WPF.CeitecStyles.Controls;assembly=Betrian.WPF.CeitecStyles"
             xmlns:converters="clr-namespace:Betrian.CflmNavi.App.Converters" xmlns:modes="clr-namespace:Betrian.CflmNavi.App.ViewModels.Modes" d:DataContext="{d:DesignInstance Type=modes:TileSetGrabbingViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EnumDisplayAttributeValueConverter x:Key="EnumDisplayAttributeValueConverter"/>
        <converters:EqualityConverter x:Key="EqualityConverter"/>
        <converters:TilesetControlEnabledConverter x:Key="TilesetControlEnabledConverter"/>
        <converters:BooleanInverseConverter x:Key="BooleanInverseConverter"/>
        <converters:BoolVisibilityCollapsedReverseConverter x:Key="BoolVisibilityCollapsedReverseConverter"/>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical" Margin="5,5,10,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,5,0,0" Visibility="{Binding AcquireTileSetOnReducedArea, Converter={StaticResource BoolVisibilityCollapsedReverseConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Grid" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" VerticalAlignment="Top" ItemsSource="{Binding ActiveProject.Holder.Grids}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedGrid}" IsEnabled="{Binding AcquireTileSetOnReducedArea, Converter={StaticResource BooleanInverseConverter}}"/>
            </Grid>

            <Grid Grid.Column="0" Margin="0,0,0,0" Visibility="{Binding AcquireTileSetOnReducedArea, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Width" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CustomTileSetRectangleWidth, Converter={StaticResource UnitConverter}}" Margin="0,5" Width="120" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Height" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomTileSetRectangleHeight, Converter={StaticResource UnitConverter}}" Margin="0" Width="120" HorizontalAlignment="Left"/>
            </Grid>
            <ToggleButton Grid.Column="1" Content="Custom" VerticalAlignment="Top" IsChecked="{Binding AcquireTileSetOnReducedArea}" IsEnabled="{Binding CustomAreaToggleEnabled}" Margin="3" Width="65"/>
        </Grid>
        <Separator Margin="0,10"/>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Acquisition" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" IsEnabled="{Binding CanAcquireTileset}">
                <Button Command="{Binding AcquireLineByLineCommand}" Margin="0,0,20,0" Height="32">
                    <ContentPresenter>
                        <ContentPresenter.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LINE BY LINE" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Image Source="{StaticResource icon_play}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ContentPresenter.ContentTemplate>
                    </ContentPresenter>
                </Button>
                <Button HorizontalAlignment="Right" Command="{Binding AcquireSpiralCommand}" Height="32" >
                    <ContentPresenter>
                        <ContentPresenter.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SPIRAL" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Image Source="{StaticResource icon_play}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ContentPresenter.ContentTemplate>
                    </ContentPresenter>
                </Button>
            </StackPanel>
        </StackPanel>
        <Separator Margin="0,10"/>
        <StackPanel Orientation="Vertical" IsEnabled="{Binding ActiveProject.Holder.Grids, Converter={StaticResource TilesetControlEnabledConverter}}">
            <TextBlock Text="Working with focus" Margin="0,0,0,15"/>
            <ItemsControl ItemsSource="{Binding TilesetGrabbingOptions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Content="{Binding Converter={StaticResource EnumDisplayAttributeValueConverter}}" GroupName="2" Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=DataContext.SetTilesetGrabbingCommand}" CommandParameter="{Binding}" Margin="0,0,0,15">
                            <RadioButton.IsChecked>
                                <MultiBinding Converter="{StaticResource EqualityConverter}" Mode="OneWay">
                                    <Binding Path="DataContext.SelectedGrabbingOption" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                    <Binding Path=""/>
                                </MultiBinding>
                            </RadioButton.IsChecked>
                        </RadioButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="Check your z-stack tab - range and count settings" Margin="0,15,0,0" Visibility="{Binding Message3DVisibility}" />
        </StackPanel>
        <Separator Margin="0,10"/>
    </StackPanel>
</UserControl>
