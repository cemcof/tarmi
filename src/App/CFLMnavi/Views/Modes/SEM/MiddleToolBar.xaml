<appControls:ApplicationModeControlBase
    x:Class="Betrian.CflmNavi.App.Views.Modes.SEM.MiddleToolBar"
    x:TypeArguments="viewModels:ElectronBeamModeViewModel"
    xmlns:appControls="clr-namespace:CFLMnavi.WPF.Controls;assembly=CFLMnavi.WPF"
    xmlns:bwpf="clr-namespace:Betrian.WPF;assembly=Betrian.WPF"
    xmlns:viewModels="clr-namespace:Betrian.CflmNavi.App.ViewModels.Modes.SEM"
    xmlns:views ="clr-namespace:Betrian.CflmNavi.App.Views"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views.Modes.SEM"
    xmlns:controls="clr-namespace:Betrian.WPF.CeitecStyles.Controls;assembly=Betrian.WPF.CeitecStyles"
    mc:Ignorable="d" 
    d:DesignHeight="64" d:DesignWidth="1000"
    xmlns:appMode="clr-namespace:CFLMnavi.WPF;assembly=CFLMnavi.WPF"
    d:DataContext="{d:DesignInstance Type=viewModels:ElectronBeamModeViewModel}"
    Tag="{x:Static appMode:ApplicationMode.SEM}"
>
    <Grid Margin="60,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="1">
            <controls:ToggleButtonIndicator Margin="5" Height="32" Content="LIVE" Command="{Binding StartGrabbingCommand}" IsChecked="{Binding IsGrabbingImage, Mode=OneWay}" Padding="0" Width="90"/>
            <Button Content="SINGLE IMAGE" Command="{Binding GrabImageCommand}" IsEnabled="{Binding GrabImageEnabled, Mode=OneWay}" Margin="5" Height="32" Padding="0"/>
            <Button Content="CAPTURE IMAGE" Command="{Binding CaptureImageCommand}" IsEnabled="{Binding CaptureImageEnabled, Mode=OneWay}" Margin="5" Height="32" Padding="0"/>
        </StackPanel>

        <views:ImageViewerControl DataContext="{Binding ImageViewerVM}" HorizontalAlignment="Right" Grid.Column="2" />
    </Grid>
</appControls:ApplicationModeControlBase>
