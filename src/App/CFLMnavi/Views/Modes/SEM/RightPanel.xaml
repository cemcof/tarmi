<appControls:ApplicationModeControlBase
    x:Class="Betrian.CflmNavi.App.Views.Modes.SEM.RightPanel"
    x:TypeArguments="viewModels:ElectronBeamModeViewModel"
    xmlns:appControls="clr-namespace:CFLMnavi.WPF.Controls;assembly=CFLMnavi.WPF"
    xmlns:bwpf="clr-namespace:Betrian.WPF;assembly=Betrian.WPF"
    xmlns:viewModels="clr-namespace:Betrian.CflmNavi.App.ViewModels.Modes.SEM"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views.Modes.SEM"
    xmlns:modes="clr-namespace:Betrian.CflmNavi.App.Views.Modes"
    xmlns:controls="clr-namespace:Betrian.WPF.CeitecStyles.Controls;assembly=Betrian.WPF.CeitecStyles"
    xmlns:betrianTypes="clr-namespace:Betrian.Devices.Thermofisher.Instrument.Types;assembly=Betrian.Devices.Thermofisher.Instrument"
    xmlns:views="clr-namespace:Betrian.CflmNavi.App.Views"
    xmlns:localControls="clr-namespace:Betrian.CflmNavi.App.Controls"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="500"
    xmlns:converters="clr-namespace:Betrian.CflmNavi.App.Converters"
    xmlns:appMode="clr-namespace:CFLMnavi.WPF;assembly=CFLMnavi.WPF"
    xmlns:sem="clr-namespace:Betrian.CflmNavi.App.ViewModels.Modes.SEM"
    d:DataContext="{d:DesignInstance Type=sem:ElectronBeamModeViewModel}"
    Tag="{x:Static appMode:ApplicationMode.SEM}"
>
    <UserControl.Resources>
        <converters:EnumDisplayAttributeValueConverter x:Key="EnumDisplayAttributeValueConverter"/>
        <converters:EqualityConverter x:Key="EqualityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="580" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="0">
            <TabItem Header="ROI">
                <views:ROIs ViewModel="{Binding RoiControl}"/>
            </TabItem>
        </TabControl>
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedLowerRightPanelTab}">
            <TabItem Header="Stage">
                <views:StageTabUserControl DataContext="{Binding}"/>
            </TabItem>
            <TabItem Header="Tileset">
                <modes:TileSetGrabbingUserControl DataContext="{Binding TileSetGrabbing}"/>
            </TabItem>
        </TabControl>
    </Grid>
</appControls:ApplicationModeControlBase>
