<UserControl x:Class="Betrian.CflmNavi.App.Views.Modes.LayersUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views.Modes" xmlns:viewmodels="clr-namespace:Betrian.CflmNavi.App.ViewModels"
             xmlns:layers="clr-namespace:Betrian.CflmNavi.App.ViewModels.Layers" d:DataContext="{d:DesignInstance Type=layers:LayersViewModel}"
             xmlns:converters="clr-namespace:Betrian.CflmNavi.App.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolVisibilityCollapsedConverter x:Key="BoolVisibilityCollapsedConverter"/>
        <converters:BoolVisibilityCollapsedReverseConverter x:Key="BoolVisibilityCollapsedReverseConverter"/>
        <converters:CameraViewToImageConverter x:Key="CameraViewToImageConverter"/>

        <DataTemplate DataType="{x:Type layers:LayeredImageDescriptorViewModel}">
            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type layers:TileSetDescriptorViewModel}">
            <TextBlock TextTrimming="CharacterEllipsis">
                <Run Text="{Binding Name}"/>
                <Run Text=","/>
                <Run Text="{Binding ImagesCount, Mode=OneWay}"/>
                <Run Text="tiles"/>
            </TextBlock>
        </DataTemplate>

        <DataTemplate DataType="{x:Type layers:ZStackDescriptorViewModel}">
            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ListBox ItemsSource="{Binding Layers}" VerticalAlignment="Top" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="600">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid Visibility="{Binding Renaming, Converter={StaticResource BoolVisibilityCollapsedConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Name}" HorizontalAlignment="Left" Margin="2,0" Width="250"/>
                            <!--TODO: TextBox should stretch automatically-->
                            <Button Grid.Column="1" Style="{StaticResource RoundButton}" Width="20" Height="20" Padding="0" Margin="3" HorizontalAlignment="Right" Command="{Binding AcceptRenameCommand}">
                                <Image Source="{StaticResource alert_green}"/>
                            </Button>
                            <Button Grid.Column="2" Style="{StaticResource RoundButton}" Width="20" Height="20" Padding="0" Margin="3" HorizontalAlignment="Right" Background="{StaticResource BackgroundBrush}" BorderThickness="0" Command="{Binding CancelRenameCommand}">
                                <Image Source="{StaticResource alert_red_2}"/>
                            </Button>
                        </Grid>
                        
                        <Grid Visibility="{Binding Renaming, Converter={StaticResource BoolVisibilityCollapsedReverseConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition />
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton IsChecked="{Binding IsVisible}" Grid.Column="0" Width="23" Padding="2" Margin="2,2,5,2" BorderThickness="2">
                                <Image Source="{StaticResource eye_green}"/>
                            </ToggleButton>
                            <ContentPresenter Content="{Binding}" ToolTip="{Binding Name}" Grid.Column="1" VerticalAlignment="Center"/>
                            <Image Grid.Column="2" Height="19" Margin="10,0" Source="{Binding Source, Converter={StaticResource CameraViewToImageConverter}}" ToolTip="{Binding Source}"/>
                            <Button Grid.Column="3" Padding="3" Margin="2" Width="NaN" Height="23" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" ToolTip="Rename" Command="{Binding StartRenameCommand}" >
                                <Image Source="{StaticResource icon_pencil}"/>
                            </Button>
                            <Button Grid.Column="4" Padding="3" Margin="2,0" Width="NaN" Height="23" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" ToolTip="Delete" Command="{Binding RemoveCommand}">
                                <Image Source="{StaticResource icon_trash}" />
                            </Button>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>
