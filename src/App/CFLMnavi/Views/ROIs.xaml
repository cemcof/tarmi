        <DataTemplate DataType="{x:Type rois:StackedImageChildVM}">
            <Border BorderBrush="{StaticResource BackgroundLightBrush}" BorderThickness="0,1,0,0" HorizontalAlignment="Stretch">
                <DockPanel Height="24">
                    <localControls:ImageSelectionToggle
                        DockPanel.Dock="Left" Padding="3" Margin="1" MinWidth="0" Width="NaN"
                        Selection="{Binding SelectionType, Mode=OneWay}" Command="{Binding ToggleVisibilityCommand}" IsEnabled="{Binding CanToggle}"
                    />
                    <controls:ThreeDotsMenu DockPanel.Dock="Right" HorizontalAlignment="Right" Height="24" Width="14" ToolTip="More actions">
                        <controls:ThreeDotsMenu.DropDown>
                            <ContextMenu>
                                <MenuItem Command="{Binding RemoveCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_trash}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Remove" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding MakeReferenceCommand}" Visibility="{Binding CanBeMarkedAsReference, Converter={StaticResource BoolVisibilityCollapsedConverter}}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_ref_image3_white}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Make Reference" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding EditFiducialsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_fiducial_point_white}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Edit Fiducials" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding EditCorrelationsOptionsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_correlation_white}" Height="16" Width="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Correlation Options" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ExportToMapsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource export}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="MAPS Export" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem>
                                    <MenuItem.Style>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header">
                                                <Setter.Value>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{StaticResource icon_lock_open_white}" Height="16" Margin="0,0,8,0" />
                                                        <ContentPresenter Content="Unbind Fiducials" />
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Command" Value="{Binding UnbindCorrelationCommand}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FiducialsGroupId}" Value="{x:Static system:Guid.Empty}">
                                                    <Setter Property="Header">
                                                        <Setter.Value>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Source="{StaticResource icon_lock_closed_white}" Height="16" Margin="0,0,8,0" />
                                                                <ContentPresenter Content="Bind Fiducials"/>
                                                            </StackPanel>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="Command" Value="{Binding BindCorrelationCommand}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <MenuItem Command="{Binding RegenerateMipImageCommand}" Visibility="Visible">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_mip_image}" Height="16" Width="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Regenerate MIP Image" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </controls:ThreeDotsMenu.DropDown>
                    </controls:ThreeDotsMenu>
                    <Button DockPanel.Dock="Right" Padding="3" Margin="2,0" Width="NaN" Height="20" Style="{StaticResource FlatButtonStyle}" Command="{Binding NavigateToStackImageCommand}" ToolTip="Navigate to stack image">
                        <Image Source="{StaticResource icon_roi}" />
                    </Button>
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding Attributes, Converter={StaticResource ImageAttributesConverter}}" Margin="4,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="2, 0, 0, 0" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type rois:SingleImageChildVM}">
            <Border BorderBrush="{StaticResource BackgroundLightBrush}" BorderThickness="0,1,0,0" HorizontalAlignment="Stretch">
                <DockPanel Height="24">
                    <localControls:ImageSelectionToggle
                        DockPanel.Dock="Left" Padding="3" Margin="1" MinWidth="0" Width="NaN"
                        Selection="{Binding SelectionType, Mode=OneWay}" Command="{Binding ToggleVisibilityCommand}" IsEnabled="{Binding CanToggle}"
                    />
                    <controls:ThreeDotsMenu DockPanel.Dock="Right" HorizontalAlignment="Right" Height="24" Width="14" ToolTip="More actions">
                        <controls:ThreeDotsMenu.DropDown>
                            <ContextMenu>
                                <MenuItem Command="{Binding RemoveCommand}" Visibility="{Binding CanBeRemoved, Converter={StaticResource BoolVisibilityCollapsedConverter}}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_trash}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Remove" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding MakeReferenceCommand}" Visibility="{Binding CanBeMarkedAsReference, Converter={StaticResource BoolVisibilityCollapsedConverter}}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_ref_image3_white}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Make Reference" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding EditFiducialsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_fiducial_point_white}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Edit Fiducials" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding EditCorrelationsOptionsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_correlation_white}" Height="16" Width="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Correlation Options" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ExportToMapsCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource export}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="MAPS Export" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding EditMillingCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{StaticResource icon_milling_white}" Height="16" Margin="0,0,8,0" />
                                            <ContentPresenter Content="Milling" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem>
                                    <MenuItem.Style>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header">
                                                <Setter.Value>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{StaticResource icon_lock_open_white}" Height="16" Margin="0,0,8,0" />
                                                        <ContentPresenter Content="Unbind Fiducials" />
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Command" Value="{Binding UnbindCorrelationCommand}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FiducialsGroupId}" Value="{x:Static system:Guid.Empty}">
                                                    <Setter Property="Header">
                                                        <Setter.Value>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Image Source="{StaticResource icon_lock_closed_white}" Height="16" Margin="0,0,8,0" />
                                                                <ContentPresenter Content="Bind Fiducials"/>
                                                            </StackPanel>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="Command" Value="{Binding BindCorrelationCommand}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                            </ContextMenu>
                        </controls:ThreeDotsMenu.DropDown>
                    </controls:ThreeDotsMenu>
                    <Button DockPanel.Dock="Right" Padding="3" Margin="2,0" Width="NaN" Height="20" Style="{StaticResource FlatButtonStyle}" Command="{Binding NavigateToImageCommand}" ToolTip="Navigate to image">
                        <Image Source="{StaticResource icon_roi}" />
                    </Button>
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding Attributes, Converter={StaticResource ImageAttributesConverter}}" Margin="4,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="2,0,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>

