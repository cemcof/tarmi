        <AlternationConverter x:Key="AlternationConverter">
            <StaticResource ResourceKey="WarningForegroundBrush"/>
            <StaticResource ResourceKey="InfoForegroundBrush"/>
        </AlternationConverter>

    </UserControl.Resources>

    <Grid DataContext="{Binding ViewModel, RelativeSource={RelativeSource AncestorType=local:ROIs}}">
        <ListBox ItemsSource="{Binding RegionsOfInterest, Mode=OneWay}" SelectedItem="{Binding SelectedRoi}" VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type rois:RoiVM}">
                    <Border>
                        <Expander IsExpanded="{Binding (Selector.IsSelected), Mode=OneWay, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Style="{StaticResource roiExpander}">
                            <Expander.Header>
                                <controls:EditableTextBlock Text="{Binding Name}" FontSize="14" />
                            </Expander.Header>
                            <ItemsControl ItemsSource="{Binding RoiChildVMs}" Width="300">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle AlternationCount="2">
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="GroupItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GroupItem">
                                                            <DockPanel LastChildFill="True">
                                                                <Border DockPanel.Dock="Left" BorderThickness="2" CornerRadius="2" Margin="0 1 3 1">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="BorderBrush" Value="{Binding RelativeSource={RelativeSource AncestorType=GroupItem, Mode=FindAncestor}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource AlternationConverter}}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Path=Name}" Value="{x:Static system:Guid.Empty}">
                                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                                <ItemsPresenter/>
                                                            </DockPanel>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                            </ItemsControl>
                        </Expander>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>
