<UserControl x:Class="Betrian.CflmNavi.App.Views.ImageViewerControl"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Betrian.CflmNavi.App.Views" 
             xmlns:viewmodels="clr-namespace:Betrian.CflmNavi.App.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:ImageViewerControlsViewModel}"
             mc:Ignorable="d">
    <StackPanel Orientation="Horizontal" Height="32" >
        <TextBlock Text="Zoom" VerticalAlignment="Center" Margin="10,0"/>
        <Button Content="-" Command="{Binding ZoomOutCommand}" Style="{StaticResource SharpCornersRightButton}" Width="30" Padding="4" />

        <Border Background="{StaticResource BackgroundLightBrush}" Width="55" Margin="1,0">
            <TextBlock Text="{Binding DisplayScale, StringFormat={}{0} %}" HorizontalAlignment="Center" VerticalAlignment="Center"  />
        </Border>
        <Button Content="+" Command="{Binding ZoomInCommand}" Style="{StaticResource SharpCornersLeftButton}" Width="30" Padding="4" />

        <Button Content="1:1" Command="{Binding Zoom100Command}" Margin="10,0,1,0" Style="{StaticResource SharpCornersRightButton}" Width="30" Padding="4"/>
        <Button Command="{Binding ZoomToFitCommand}" Style="{StaticResource SharpCornersLeftButton}" Width="30" Padding="6">
            <Image Source="{StaticResource icon_focus}" />
        </Button>
    </StackPanel>
</UserControl>
