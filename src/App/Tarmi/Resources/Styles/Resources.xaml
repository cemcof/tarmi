<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:Tarmi.App.Views"
                    xmlns:controls="clr-namespace:Tarmi.WPF.CeitecStyles.Controls;assembly=Tarmi.WPF.CeitecStyles"
                    xmlns:localControls ="clr-namespace:Tarmi.App.Controls"
                    xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
                    xmlns:converters="clr-namespace:Tarmi.App.Converters"
                    xmlns:bwpfConverters="clr-namespace:Tarmi.WPF.Converters;assembly=Tarmi.WPF"
                    >

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="DataTemplates.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <bwpfConverters:Multiply x:Key="multiplyConverter"/>
    <converters:HumanIndexConverter x:Key="HumanIndexConverter" />

    <Style TargetType="{x:Type localControls:ModeSelector}" BasedOn="{StaticResource {x:Type controls:ContentSelector}}" />

    <ControlTemplate TargetType="{x:Type localControls:EnhancedSlider}" x:Key="enhancedSliderTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <RepeatButton x:Name="PART_ButtonMinus" Content="-" Grid.Column="0" Height="24" Width="24" Style="{StaticResource RoundButton}" Command="{x:Static Slider.DecreaseSmall}"/>
            <Slider x:Name="PART_Slider" Grid.Column="1" Margin="10,0" VerticalAlignment="Center"
                    Value="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type localControls:EnhancedSlider}}}"
                    Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType={x:Type localControls:EnhancedSlider}}}"
                    Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType={x:Type localControls:EnhancedSlider}}}"
                    TickFrequency="{Binding TickFrequency, RelativeSource={RelativeSource AncestorType={x:Type localControls:EnhancedSlider}}}"
                    SmallChange="{Binding SmallChange, RelativeSource={RelativeSource AncestorType={x:Type localControls:EnhancedSlider}}}"
                    IsSnapToTickEnabled="{Binding IsSnapToTickEnabled, RelativeSource={RelativeSource AncestorType={x:Type localControls:EnhancedSlider}}}"
                    IsMoveToPointEnabled="True"/>
            <RepeatButton x:Name="PART_ButtonPlus" Content="+" Grid.Column="2" Height="24" Width="24" Style="{StaticResource RoundButton}" Command="{x:Static Slider.IncreaseSmall}"/>
            <TextBox x:Name="PART_TextBox" Text="{Binding ElementName=PART_Slider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.####}, Delay=700}" Grid.Column="3" Width="75" Margin="10,0,0,0"/>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type localControls:EnhancedSlider}">
        <Setter Property="Template" Value="{StaticResource enhancedSliderTemplate}"/>
    </Style>

    <ControlTemplate TargetType="{x:Type localControls:SpinBox}" x:Key="SpinBoxTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <RepeatButton Content="-" Grid.Column="0" Height="24" Width="24" Style="{StaticResource RoundButton}"
                          Command="{Binding Path=DecrementCommand, RelativeSource={RelativeSource AncestorType=localControls:SpinBox}}"/>
            <TextBox Grid.Column="1" TextAlignment="Center" Margin="5 0"
                     Text="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=localControls:SpinBox}, StringFormat=0.##}"/>
            <RepeatButton Content="+" Grid.Column="2" Height="24" Width="24" Style="{StaticResource RoundButton}"
                          Command="{Binding Path=IncrementCommand, RelativeSource={RelativeSource AncestorType=localControls:SpinBox}}"/>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type localControls:SpinBox}">
        <Setter Property="Template" Value="{StaticResource SpinBoxTemplate}"/>
    </Style>

    <ControlTemplate TargetType="{x:Type localControls:LogarithmicSlider}" x:Key="logarithmicSliderTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <RepeatButton x:Name="PART_ButtonMinus" Content="-" Grid.Column="0" Height="24" Width="24" Style="{StaticResource RoundButton}" Command="{x:Static Slider.DecreaseSmall}"/>
            <Slider x:Name="PART_LogSlider" Grid.Column="1" Margin="10,0" VerticalAlignment="Center"
                Value="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}}"
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}}"
                TickFrequency="{Binding TickFrequency, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}}"
                SmallChange="{Binding SmallChange, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}}"
                IsSnapToTickEnabled="{Binding IsSnapToTickEnabled, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}}"
                IsMoveToPointEnabled="True"/>
            <RepeatButton x:Name="PART_ButtonPlus" Content="+" Grid.Column="2" Height="24" Width="24" Style="{StaticResource RoundButton}" Command="{x:Static Slider.IncreaseSmall}"/>
            <TextBox x:Name="PART_TextBox" Text="{Binding LogValue, RelativeSource={RelativeSource AncestorType={x:Type localControls:LogarithmicSlider}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.####}, Delay=700}" Grid.Column="3" Width="75" Margin="10,0,0,0"/>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type localControls:LogarithmicSlider}">
        <Setter Property="Template" Value="{StaticResource logarithmicSliderTemplate}"/>
    </Style>

    <Style TargetType="{x:Type localControls:ScrollDragZoomControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid x:Name="PART_Grid" ClipToBounds="True" Background="Transparent" IsManipulationEnabled="True">
                        <ContentPresenter IsHitTestVisible="True" x:Name="PART_Content">
                            <ContentPresenter.RenderTransform>
                                <MatrixTransform x:Name="PART_Transform" />
                            </ContentPresenter.RenderTransform>
                        </ContentPresenter>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type localControls:ScaleBar}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:ScaleBar}">
                    <Border Background ="#55000000" CornerRadius="{StaticResource CornerRadiusThickness}">
                        <StackPanel Orientation="Horizontal">
                            <Grid>
                                <ItemsControl ItemsSource="{TemplateBinding Bars}" x:Name="PART_Segments" Margin="0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="{Binding Length}">
                                                <Border BorderThickness="1,0,0,0" Height="10" BorderBrush="White" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding Label, StringFormat={}{0:0.##}}" Foreground="White" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <DockPanel Margin="0,8">
                                    <Border DockPanel.Dock="Left" Width="{Binding SegmentHalfLength, RelativeSource={RelativeSource AncestorType={x:Type localControls:ScaleBar}}}"/>
                                    <Border DockPanel.Dock="Right" Width="{Binding SegmentHalfLength, RelativeSource={RelativeSource AncestorType={x:Type localControls:ScaleBar}}}"/>
                                    <Border BorderBrush="White" BorderThickness="0,1,0,0" Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,5,0,0"/>
                                </DockPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,8,16,8">
                                <TextBlock Text="{Binding SizePrefix, RelativeSource={RelativeSource AncestorType={x:Type localControls:ScaleBar}}}" Foreground="White"/>
                                <TextBlock Text="{Binding PixelSizeUnit, RelativeSource={RelativeSource AncestorType={x:Type localControls:ScaleBar}}}" Foreground="White" Margin="2,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type localControls:ImageControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid x:Name="PART_Grid" ClipToBounds="True" UseLayoutRounding="False" Background="Transparent">
                        <Grid x:Name="PART_Content">
                            <Image Source="{Binding ImageSource, RelativeSource={RelativeSource AncestorType=localControls:ImageControl}}" Stretch="Uniform" x:Name="PART_Image" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.RenderTransform>
                                    <MatrixTransform x:Name="PART_Transform" />
                                </Image.RenderTransform>
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor" />
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>

                        <localControls:TransformCanvas Transform="{Binding Transform, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"
                                                       Visibility="{Binding IsCenterCrossVisible, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid IsHitTestVisible="False" Margin="-20,-20" Canvas.Left="{Binding Source.Width, ElementName=PART_Image, Converter={StaticResource multiplyConverter}, ConverterParameter=0.5}"
                                   Canvas.Top="{Binding Source.Height, ElementName=PART_Image, Converter={StaticResource multiplyConverter}, ConverterParameter=0.5}">
                                <Line X1="0" X2="40" Y1="20" Y2="20" Stroke="{StaticResource InfoForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="20" X2="20" Y1="0" Y2="40" Stroke="{StaticResource InfoForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </localControls:TransformCanvas>

                        <ContentControl Content="{Binding Content, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"
                        UseLayoutRounding="False" />

                        <localControls:ScaleBar x:Name="PART_ScaleBar" Height="40" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="{StaticResource BackgroundLightBrush}" Foreground="{StaticResource ForegroundBrush}" Margin="10"
                        BarParts="10" MaxBarsPixelLength="{Binding ActualWidth, ElementName=PART_Grid, Converter={StaticResource multiplyConverter}, ConverterParameter=0.6}"
                                                Visibility="{Binding IsScaleBarVisible, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <localControls:ScaleBar.ZoomScale>
                                <MultiBinding Converter="{StaticResource multiplyConverter}">
                                    <Binding Path="Transform.M11" RelativeSource="{RelativeSource AncestorType={x:Type localControls:ImageControl}}"/>
                                    <Binding Path="Zoom" RelativeSource="{RelativeSource AncestorType={x:Type localControls:ImageControl}}"/>
                                </MultiBinding>
                            </localControls:ScaleBar.ZoomScale>
                        </localControls:ScaleBar>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type localControls:RelativeSlider}">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="150"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:RelativeSlider}">
                    <Border Background="{TemplateBinding Background}" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" CornerRadius="{StaticResource CornerRadiusThickness}">
                        <Border Margin="2" CornerRadius="3">
                            <Border.Background>
                                <DrawingBrush TileMode="Tile" ViewboxUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Brush="#ccffffff">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0.0,0.0,1.0,0.1" RadiusX="0.1" RadiusY="0.02" />
                                                    <RectangleGeometry Rect="0.0,0.2,1.0,0.1" RadiusX="0.1" RadiusY="0.02" />
                                                    <RectangleGeometry Rect="0.0,0.4,1.0,0.1" RadiusX="0.1" RadiusY="0.02" />
                                                    <RectangleGeometry Rect="0.0,0.6,1.0,0.1" RadiusX="0.1" RadiusY="0.02" />
                                                    <RectangleGeometry Rect="0.0,0.8,1.0,0.1" RadiusX="0.1" RadiusY="0.02" />
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                    <DrawingBrush.RelativeTransform>
                                        <TranslateTransform Y="{Binding DisplayOffset,RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                                    </DrawingBrush.RelativeTransform>
                                </DrawingBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="HistogramSlider" TargetType="{x:Type controls:DualSlider}">
        <Border x:Name="border" Background="{x:Null}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
            <Canvas x:Name="PART_Canvas" Margin="-4,0,4,0">
                <Thumb x:Name="PART_LowerThumb" Focusable="False" OverridesDefaultStyle="True" VerticalAlignment="Stretch" Height="{Binding ActualHeight ,ElementName=PART_Canvas}">
                    <Thumb.Template>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Grid Background="Transparent">
                                <Border Width="1" Background="{StaticResource HighlightBrush}" HorizontalAlignment="Center"/>
                                <Path x:Name="arrow" Data="F1 M 0,8 L 8,8 L 4,0 L 0,8 Z " Fill="{StaticResource HighlightBrush}" HorizontalAlignment="Center" Margin="0" VerticalAlignment="Bottom"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <Thumb x:Name="PART_UpperThumb" Focusable="False" OverridesDefaultStyle="True" VerticalAlignment="Stretch" Height="{Binding ActualHeight ,ElementName=PART_Canvas}">
                    <Thumb.Template>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Grid Background="Transparent">
                                <Border Width="1" Background="{StaticResource HighlightBrush}" HorizontalAlignment="Center"/>
                                <Path x:Name="arrow" Data="F1 M 0,8 L 8,8 L 4,0 L 0,8 Z " Fill="{StaticResource HighlightBrush}" HorizontalAlignment="Center" Margin="0" VerticalAlignment="Bottom"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

            </Canvas>
        </Border>
    </ControlTemplate>

    <Style TargetType="{x:Type localControls:ZStackSlider}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:ZStackSlider}">
                    <Border x:Name="border" Background="{StaticResource BackgroundLightBrush}" CornerRadius="{StaticResource CornerRadiusThicknessLarge}" SnapsToDevicePixels="True"
                            Width="100" ClipToBounds="True">
                        <Canvas x:Name="PART_Canvas" Margin="0,8,0,0" VerticalAlignment="Stretch">
                            <Rectangle Margin="0,0,0,4" Width="60" HorizontalAlignment="Center" x:Name="PART_StripedRectangle" Canvas.Left="20" Height="250">
                                <Rectangle.Fill>
                                    <LinearGradientBrush MappingMode="Absolute" StartPoint="0,0" EndPoint="0,8" SpreadMethod="Repeat">
                                        <GradientStop Offset="0" Color="Transparent"/>
                                        <GradientStop Offset="0.3" Color="Transparent"/>
                                        <GradientStop Offset="0.5" Color="{StaticResource HighlightColor}"/>
                                        <GradientStop Offset="0.7" Color="Transparent"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <Rectangle Opacity="0.8" Fill="{StaticResource BackgroundLightBrush}" Width="60" HorizontalAlignment="Center" Canvas.Left="20" Height="250" Margin="0,0,0,4" Canvas.Bottom="{Binding (Canvas.Bottom), ElementName=PART_UpperThumb}"/>
                            <Rectangle Opacity="0.8" Fill="{StaticResource BackgroundLightBrush}" Width="60" HorizontalAlignment="Center" Canvas.Left="20" Height="250" Margin="0,0,0,-246" Canvas.Bottom="{Binding (Canvas.Bottom), ElementName=PART_LowerThumb}"/>

                            <Thumb x:Name="PART_LowerThumb" Focusable="False" OverridesDefaultStyle="True" HorizontalAlignment="Stretch" Width="{Binding ActualWidth ,ElementName=PART_Canvas}" Cursor="SizeNS">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <DockPanel Background="Transparent" Margin="5,0">
                                            <Border Width="10" Height="8" Background="{StaticResource ForegroundBrush}" CornerRadius="4,0,0,4" DockPanel.Dock="Left" />
                                            <Border Width="10" Height="8" Background="{StaticResource ForegroundBrush}" CornerRadius="0,4,4,0" DockPanel.Dock="Right" />
                                            <Border Height="4" Background="{StaticResource ForegroundBrush}" />
                                        </DockPanel>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <Thumb x:Name="PART_UpperThumb" Focusable="False" OverridesDefaultStyle="True" HorizontalAlignment="Stretch" Width="{Binding ActualWidth ,ElementName=PART_Canvas}" Cursor="SizeNS">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <DockPanel Background="Transparent" Margin="5,0">
                                            <Border Width="10" Height="8" Background="{StaticResource ForegroundBrush}" CornerRadius="4,0,0,4" DockPanel.Dock="Left" />
                                            <Border Width="10" Height="8" Background="{StaticResource ForegroundBrush}" CornerRadius="0,4,4,0" DockPanel.Dock="Right" />
                                            <Border Height="4" Background="{StaticResource ForegroundBrush}" />
                                        </DockPanel>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <Thumb x:Name="PART_ValueThumb" IsEnabled="False" Focusable="False" OverridesDefaultStyle="True" HorizontalAlignment="Stretch" Width="{Binding ActualWidth ,ElementName=PART_Canvas}" Cursor="SizeNS">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <DockPanel Background="Transparent" Margin="15,0,15,2">
                                            <Path Data="F1 M 0,4 L 4,0 L 4,4 L 0,4 Z " Fill="{StaticResource ForegroundLightBrush}" DockPanel.Dock="Left"/>
                                            <Path Data="F1 M 0,4 L 0,0 L 4,4 L 0,4 Z " Fill="{StaticResource ForegroundLightBrush}" DockPanel.Dock="Right"/>
                                            <Border Height="4" Background="{StaticResource ForegroundLightBrush}" />
                                        </DockPanel>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type localControls:ZStackSlider}" x:Key="VerticalToolbarZStackSlider">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:ZStackSlider}">
                    <Border x:Name="border"
                            Background="{StaticResource BackgroundLightBrush}"
                            BorderBrush="{StaticResource Gray70Brush}"
                            CornerRadius="{StaticResource CornerRadiusThicknessLarge}"
                            BorderThickness="1px" SnapsToDevicePixels="True"
                            Padding="0,12,0,4"
                            Width="40" ClipToBounds="True" >
                        <Canvas x:Name="PART_Canvas" Margin="0,0,0,0" VerticalAlignment="Stretch">
                            <Rectangle Margin="0,0,0,0" Width="30" HorizontalAlignment="Center" x:Name="PART_StripedRectangle" Canvas.Left="4" Canvas.Right="4" Canvas.Top="-8" Canvas.Bottom="0" Height="240">
                                <Rectangle.Fill>
                                    <LinearGradientBrush MappingMode="Absolute" StartPoint="0,0" EndPoint="0,8" SpreadMethod="Repeat">
                                        <GradientStop Offset="0" Color="Transparent"/>
                                        <GradientStop Offset="0.3" Color="Transparent"/>
                                        <GradientStop Offset="0.5" Color="{StaticResource Gray40}"/>
                                        <GradientStop Offset="0.7" Color="Transparent"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <Thumb x:Name="PART_ValueThumb" IsEnabled="False" Focusable="False" OverridesDefaultStyle="True" HorizontalAlignment="Stretch" Width="{Binding ActualWidth ,ElementName=PART_Canvas}" Cursor="SizeNS">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Height="3" Background="{StaticResource ForegroundLightBrush}" Margin="4,2,4,2"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type localControls:PromptDialog}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:PromptDialog}">
                    <Border CornerRadius="10" Background="{StaticResource BackgroundBrush}" Padding="15,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Prompt}" FontSize="16" Foreground="{StaticResource ForegroundLightBrush}" Margin="0,10,0,10" TextWrapping="Wrap" Width="250"/>
                            <TextBox Grid.Row="1" Margin="0,0,0,15" x:Name="PART_Input" Width="NaN">
                                <TextBox.Text>
                                    <Binding Path="Value" UpdateSourceTrigger="PropertyChanged">
                                        <Binding.ValidationRules>
                                            <ExceptionValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center">
                                <Button Content="Ok" Margin="0,0,5,0" x:Name="PART_Ok" Style="{StaticResource HighlightButtonStyle}" IsDefault="True"/>
                                <Button Content="Cancel" Margin="5,0,0,0" x:Name="PART_Cancel" IsCancel="True"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource BaseButtonStyle}" TargetType="{x:Type ToggleButton}" x:Key="RoiHeaderToggleButtonTemplate">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border
                        x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true" CornerRadius="{StaticResource CornerRadiusThickness}"
                    >
                        <ContentPresenter 
                            x:Name="contentPresenter" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter Property="Background" TargetName="border" Value="Transparent"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource ForegroundDarkBrush}"/>
                            <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource ForegroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" TargetName="border" Value="Transparent"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrush}"/>
                            <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource HighlightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter Property="Background" TargetName="border" Value="Transparent"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrush}"/>
                            <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource HighlightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Background" TargetName="border" Value="Transparent"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource BackgroundLightBrush}"/>
                            <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource ForegroundDarkBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource BaseButtonStyle}" TargetType="{x:Type localControls:ImageSelectionToggle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:ImageSelectionToggle}">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="true"
                        CornerRadius="{StaticResource CornerRadiusThickness}"
                    >
                        <Image x:Name="PART_Image" HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16" Margin="4,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrush}"/>
                        </Trigger>
                        <Trigger Property="Selection" Value="Unselected">
                            <Setter Property="Background" TargetName="border" Value="{StaticResource ForegroundDarkBrush}"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource ForegroundDarkBrush}"/>
                            <Setter Property="Source" TargetName="PART_Image" Value="{StaticResource eye_white}"/>
                        </Trigger>
                        <Trigger Property="Selection" Value="Primary">
                            <Setter Property="Background" TargetName="border" Value="{StaticResource ForegroundDarkBrush}"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource HighlightBrush}"/>
                            <Setter Property="Source" TargetName="PART_Image" Value="{StaticResource eye_green}"/>
                        </Trigger>
                        <Trigger Property="Selection" Value="Overlay">
                            <Setter Property="Background" TargetName="border" Value="{StaticResource ForegroundDarkBrush}"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource YellowForegroundBrush}"/>
                            <Setter Property="Source" TargetName="PART_Image" Value="{StaticResource eye_yellow}"/>
                        </Trigger>
                        <Trigger Property="Selection" Value="Secondary">
                            <Setter Property="Background" TargetName="border" Value="{StaticResource ForegroundDarkBrush}"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource InfoForegroundBrush}"/>
                            <Setter Property="Source" TargetName="PART_Image" Value="{StaticResource eye_blue}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter Property="Background" TargetName="border" Value="{StaticResource HighlightMutedBrush}"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource ForegroundLightBrush}"/>
                            <Setter Property="Source" TargetName="PART_Image" Value="{StaticResource eye_white}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Background" TargetName="border" Value="{StaticResource BackgroundDarkBrush}"/>
                            <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource BackgroundLightBrush}"/>
                            <Setter Property="Source" TargetName="PART_Image" Value="{StaticResource eye_gray}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="SliderThumbDisabled" TargetType="{x:Type Thumb}">
        <Ellipse x:Name="grip" Fill="{StaticResource ForegroundDarkBrush}" Stroke="{StaticResource  BackgroundDarkBrush}" StrokeThickness="2" Width="16" Height="16"
             HorizontalAlignment="Center" UseLayoutRounding="True" VerticalAlignment="Center"/>
    </ControlTemplate>

    <ControlTemplate TargetType="{x:Type localControls:ImageStackSlider}" x:Key="imageStackSliderTemplate">
        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageStackSlider}}}" HorizontalAlignment="Center" Margin="0,5"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition MinWidth="{TemplateBinding MinWidth}" Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TrackBackground" Background="{StaticResource BackgroundDarkBrush}" Grid.Column="1" HorizontalAlignment="center" Margin="0,5" Width="16" CornerRadius="7">
                        <Canvas Margin="0,-6">
                            <Rectangle x:Name="PART_SelectionRange" Fill="{StaticResource HighlightMutedBrush}" Visibility="Hidden" Width="9.0"/>
                        </Canvas>
                    </Border>
                    <Track x:Name="PART_Track" Grid.Column="1" Orientation="Vertical">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource RepeatButtonTransparent}"/>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource RepeatButtonTransparent}"/>
                        </Track.IncreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb x:Name="Thumb" Focusable="False" OverridesDefaultStyle="True" Template="{StaticResource SliderThumb}" VerticalAlignment="Center"/>
                        </Track.Thumb>
                    </Track>
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Bottom" Margin="0,5" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageStackSlider}}, Converter={StaticResource HumanIndexConverter}}" HorizontalAlignment="Center"/>
                    <TextBlock Text="-" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Maximum, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageStackSlider}}, Converter={StaticResource HumanIndexConverter}}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="false">
                <Setter Property="Template" TargetName="Thumb" Value="{StaticResource SliderThumbDisabled}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type localControls:ImageStackSlider}">
        <Setter Property="Template" Value="{StaticResource imageStackSliderTemplate}"/>
    </Style>



</ResourceDictionary>
