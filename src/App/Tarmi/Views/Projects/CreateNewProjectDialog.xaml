<bwpf:DarkDialog x:Class="Tarmi.App.Views.Projects.CreateNewProjectDialog"
                 x:TypeArguments="viewModels:CreateNewProjectDialogViewModel"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Tarmi.App.Views.Projects"
                 xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.Projects"
                 xmlns:controls="clr-namespace:Tarmi.WPF.CeitecStyles.Controls;assembly=Tarmi.WPF.CeitecStyles"
                 d:DataContext="{d:DesignInstance Type=viewModels:CreateNewProjectDialogViewModel}"
                 mc:Ignorable="d"
                 WindowStyle="None"
                 WindowStartupLocation="CenterScreen"
                 AllowsTransparency="True"
                 Width="600"
                 Height="650"
                 Background="Transparent">
    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="10">
        <Grid>
            <!--
                TODO: Get rid of render transform.
                ALT: FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource ForegroundLightBrush}" Content="&#xE711;"
            -->
            <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="15" Width="Auto"
                    Command="{Binding CancelCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </ControlTemplate>
                </Button.Template>
                <Image Source="{StaticResource button_icon_plus}" Width="20">
                    <Image.RenderTransform>
                        <RotateTransform CenterX="10" CenterY="10" Angle="45" />
                    </Image.RenderTransform>
                </Image>
            </Button>

            <local:CreateNewProjectUserControl Margin="75"/>
        </Grid>
    </Border>
</bwpf:DarkDialog>
