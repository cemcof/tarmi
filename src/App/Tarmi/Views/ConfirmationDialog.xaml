<bwpf:DarkWindow
    x:Class="Tarmi.App.Views.ConfirmationDialog"
    x:TypeArguments="viewModels:ConfirmationDialogViewModel"
    xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels"
    xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Tarmi.App.Views"
    mc:Ignorable="d"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    WindowStartupLocation="CenterOwner"
    SizeToContent="WidthAndHeight"
    d:DataContext="{d:DesignInstance Type={x:Type viewModels:ConfirmationDialogViewModel}}">
    <Border CornerRadius="10"
        Background="{StaticResource BackgroundBrush}" Padding="20 15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}" FontSize="20" Foreground="{StaticResource ForegroundLightBrush}" Margin="0 0 0 16" />
            <TextBlock Grid.Row="1" Text="{Binding Text}" Margin="0 0 0 16" />
            <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right">
                <Button Content="{Binding RejectText}" Command="{Binding RejectCommand}" Margin="0 0 8 0" IsCancel="True" />
                <Button Content="{Binding AcceptText}" Command="{Binding AcceptCommand}" Margin="0 0 0 0" IsDefault="True" Style="{StaticResource HighlightButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</bwpf:DarkWindow>
