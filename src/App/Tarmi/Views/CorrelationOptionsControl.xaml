<UserControl x:Class="Tarmi.App.Views.CorrelationOptionsControl"
             xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
             xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.ROIs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Tarmi.App.Views"
             xmlns:localControls="clr-namespace:Tarmi.App.Controls"
             d:DataContext="{d:DesignInstance Type=viewModels:CorrelationOptionsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="280">
    <StackPanel Orientation="Vertical" Margin="10,5,10,0">
        <StackPanel Orientation="Horizontal" Margin="0,10,0,20">
            <Image Source="{StaticResource icon_correlation_white}" Width="16"/>
            <TextBlock Text="Correlation Options" VerticalAlignment="Center" Foreground="White" Margin="5"/>
        </StackPanel>
        <TextBlock Text="Opacity" Margin="0,0,0,4"/>
        <localControls:EnhancedSlider
            Value="{Binding Opacity}" SetValueCommand="{Binding SetOpacityCommand}"
            Maximum="{Binding OpacityMax}" Minimum="{Binding OpacityMin}"
            TickFrequency="{Binding OpacityStep}" SmallChange="{Binding OpacityStep}"
            IsSnapToTickEnabled="True" HorizontalAlignment="Stretch"
            ToolTip="Correlation Opacity in Percent"
        />
        <Button Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Command="{Binding CloseCommand}" Width="80" Height="28" Margin="0,10,0,0">
            <ContentPresenter>
                <ContentPresenter.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <!--<Image Source="{StaticResource aim_blue}" Width="20" Margin="0,0,8,0"/>-->
                            <TextBlock Text="CLOSE" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ContentPresenter.ContentTemplate>
            </ContentPresenter>
        </Button>
    </StackPanel>
</UserControl>
