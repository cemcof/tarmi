<bwpf:ControlBase x:Class="Tarmi.App.Views.SampleSubControl" x:TypeArguments="viewModels:SampleSubModuleViewModel"
                  xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
                  xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels"

                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:Tarmi.App.Views"
                  d:DataContext="{d:DesignInstance Type=viewModels:SampleSubModuleViewModel}"
                  mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</bwpf:ControlBase>
