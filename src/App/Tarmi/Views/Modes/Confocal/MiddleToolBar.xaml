<appControls:ApplicationModeControlBase
    x:Class="Tarmi.App.Views.Modes.Confocal.MiddleToolBar"
    x:TypeArguments="viewModels:ConfocalModeViewModel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:appControls="clr-namespace:Tarmi.App.WPF.Controls;assembly=Tarmi.App.WPF"
    xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
    xmlns:local="clr-namespace:Tarmi.App.Views.Modes.Confocal"
    xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.Modes.Confocal"
    xmlns:views ="clr-namespace:Tarmi.App.Views"
    xmlns:controls="clr-namespace:Tarmi.WPF.CeitecStyles.Controls;assembly=Tarmi.WPF.CeitecStyles"
    mc:Ignorable="d" 
    d:DesignHeight="64" d:DesignWidth="1000"
    xmlns:appMode="clr-namespace:Tarmi.App.WPF;assembly=Tarmi.App.WPF"
    d:DataContext="{d:DesignInstance Type=viewModels:ConfocalModeViewModel}"
    Tag="{x:Static appMode:ApplicationMode.Confocal}">

    <Grid Margin="60,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="1">
            <controls:ToggleButtonIndicator Margin="5" Height="32" Content="TUNING" Command="{Binding StartGrabbingCommand}" IsChecked="{Binding IsGrabbingImage, Mode=OneWay}" Padding="0" Width="90"/>
            <Button Content="SINGLE IMAGE" Command="{Binding GrabImageCommand}" IsEnabled="{Binding GrabImageEnabled, Mode=OneWay}" Margin="5" Height="32" Padding="0"/>
            <Button Content="CAPTURE IMAGE" Command="{Binding CaptureImageCommand}" IsEnabled="{Binding CaptureImageEnabled, Mode=OneWay}" Margin="5" Height="32" Padding="0"/>
        </StackPanel>

        <views:ImageViewerControl DataContext="{Binding ImageViewerVM}" HorizontalAlignment="Right" Grid.Column="2" />
    </Grid>
</appControls:ApplicationModeControlBase>
