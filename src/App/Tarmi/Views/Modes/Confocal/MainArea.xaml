<appControls:ApplicationModeControlBase
    x:Class="Tarmi.App.Views.Modes.Confocal.MainArea"
    x:TypeArguments="viewModels:ConfocalModeViewModel"
    xmlns:appControls="clr-namespace:Tarmi.App.WPF.Controls;assembly=Tarmi.App.WPF"
    xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
    xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.Modes.Confocal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tarmi.App.Views.Modes.Confocal"
    xmlns:localControls="clr-namespace:Tarmi.App.Controls"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800"
    xmlns:appMode="clr-namespace:Tarmi.App.WPF;assembly=Tarmi.App.WPF"
    d:DataContext="{d:DesignInstance Type=viewModels:ConfocalModeViewModel}"
    Tag="{x:Static appMode:ApplicationMode.Confocal}">

    <Grid>
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </Grid.Resources>
        <UniformGrid Rows="1">
            <localControls:ImageControl MouseClickCommand="{Binding StageMoveClickCommand}" ImageWithMetadata="{Binding ImageWithMetadata}" 
                                        Zoom="{Binding ImageViewerVM.Scale}" ImageScale="{Binding ImageViewerVM.ImageScale, Mode=OneWayToSource}" IsScaleBarVisible="{Binding IsScaleBarVisible}"
                                        IsCenterCrossVisible="{Binding ImageOverlayToggles.IsCenterCrossVisible}">
                <Grid>
                    <ItemsControl ItemsSource="{Binding RoiControl.ROIPoints}" Visibility="{Binding IsMarksLayerVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <localControls:TransformCanvas Transform="{Binding Transform, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding FocusPointControl.AvailableFocusPoints}" Visibility="{Binding IsMarksLayerVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <localControls:TransformCanvas Transform="{Binding Transform, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding PrimaryFiducialPointControl.Fiducials}" Visibility="{Binding IsMarksLayerVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <localControls:TransformCanvas Transform="{Binding Transform, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding FieldSelectionViewModel.FieldSelectionArea}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas>
                                    <Canvas.RenderTransform>
                                        <ScaleTransform ScaleX="{Binding ImageScale, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"
                                    ScaleY="{Binding ImageScale, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}" />
                                    </Canvas.RenderTransform>
                                </Canvas>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Grid>
            </localControls:ImageControl>

            <localControls:ImageControl Visibility="{Binding ShowSecondaryImage, Converter={StaticResource BooleanToVisibilityConverter}}" ImageWithMetadata="{Binding SecondaryImageWithMetadata}" IsScaleBarVisible="{Binding IsScaleBarVisible}">
                <Grid>
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding ImageOverlayToggles.IsCenterCrossVisible, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False">
                        <Line X1="0" X2="40" Y1="20" Y2="20" Stroke="{StaticResource InfoForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="20" X2="20" Y1="0" Y2="40" Stroke="{StaticResource InfoForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding RoiControl.SecondaryROIPoints}" Visibility="{Binding IsMarksLayerVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <localControls:TransformCanvas Transform="{Binding Transform, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding SecondaryFiducialPointControl.Fiducials}" Visibility="{Binding IsMarksLayerVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <localControls:TransformCanvas Transform="{Binding Transform, RelativeSource={RelativeSource AncestorType={x:Type localControls:ImageControl}}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Path=X, Mode=TwoWay}" />
                                <Setter Property="Canvas.Top" Value="{Binding Path=Y, Mode=TwoWay}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Grid>
            </localControls:ImageControl>
            <UniformGrid.Style>
                <Style TargetType="{x:Type UniformGrid}">
                    <Setter Property="Columns" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowSecondaryImage}" Value="True">
                            <Setter Property="Columns" Value="2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </UniformGrid.Style>
        </UniformGrid>
    </Grid>
</appControls:ApplicationModeControlBase>
