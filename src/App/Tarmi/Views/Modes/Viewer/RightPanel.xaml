<appControls:ApplicationModeControlBase
    x:Class="Tarmi.App.Views.Modes.Viewer.RightPanel"
    x:TypeArguments="viewModels:ViewerViewModel"
    xmlns:appControls="clr-namespace:Tarmi.App.WPF.Controls;assembly=Tarmi.App.WPF"
    xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
    xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.Modes.Viewer"
    xmlns:controls="clr-namespace:Tarmi.WPF.CeitecStyles.Controls;assembly=Tarmi.WPF.CeitecStyles"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Tarmi.App.Views.Modes.Viewer"
    xmlns:views="clr-namespace:Tarmi.App.Views"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="500"
    d:DataContext="{d:DesignInstance Type=viewModels:ViewerViewModel}"
    xmlns:appMode="clr-namespace:Tarmi.App.WPF;assembly=Tarmi.App.WPF"
    Tag="{x:Static appMode:ApplicationMode.Viewer}"
>
    <Grid>
        <TabControl Grid.Row="0">
            <TabItem Header="Layers"/>
        </TabControl>
    </Grid>
</appControls:ApplicationModeControlBase>
