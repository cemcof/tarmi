<appControls:ApplicationModeControlBase
    x:Class="Tarmi.App.Views.Modes.Viewer.MainArea"
    x:TypeArguments="viewModels:ViewerViewModel"
    xmlns:appControls="clr-namespace:Tarmi.App.WPF.Controls;assembly=Tarmi.App.WPF"
    xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
    xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.Modes.Viewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Tarmi.App.Views.Modes.Viewer"
    xmlns:controls="clr-namespace:Tarmi.App.Controls"
    xmlns:converters="clr-namespace:Tarmi.App.Converters"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800"
    xmlns:appMode="clr-namespace:Tarmi.App.WPF;assembly=Tarmi.App.WPF"
    d:DataContext="{d:DesignInstance Type=viewModels:ViewerViewModel}"
    Tag="{x:Static appMode:ApplicationMode.Viewer}"
>
    <UserControl.Resources>
        <converters:BoolVisibilityCollapsedConverter x:Key="BoolVisibilityCollapsedConverter" />
    </UserControl.Resources>
    <Grid>
        <!-- disabled at this moment
        <controls:ImageViewerWithScaleBar ImageWithMetadata="{Binding ImageWithMetadata}">
            <Grid>
                <controls:ClickArea Background="Transparent" Click="{Binding AreaClickCommand}" Scale="{Binding ImageScale, RelativeSource={RelativeSource AncestorType={x:Type controls:ImageViewerWithScaleBar}}}" />
                <ItemsControl ItemsSource="{Binding DisplayItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ScaledCanvas Scale="{Binding ImageScale, RelativeSource={RelativeSource AncestorType={x:Type controls:ImageViewerWithScaleBar}}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Path=X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Path=Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding MillingAreas}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas>
                                <Canvas.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding ImageScale, RelativeSource={RelativeSource AncestorType={x:Type controls:ImageViewerWithScaleBar}}}"
                                                    ScaleY="{Binding ImageScale, RelativeSource={RelativeSource AncestorType={x:Type controls:ImageViewerWithScaleBar}}}"/>
                                </Canvas.LayoutTransform>
                            </Canvas>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Path=X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Path=Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Grid>
        </controls:ImageViewerWithScaleBar>
        -->
        <StackPanel IsEnabled="{Binding IsInitialized}" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" >
            <Button Command="{Binding NavigateToSemViewCommand}" Padding="16" Margin="4" ToolTip="Switch to SEM mode" >
                <Button.Content>
                    <StackPanel Orientation="Vertical">
                        <Image Source="{StaticResource icon_atom_white}" Height="64"/>
                        <Label Content="SEM" HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Command="{Binding NavigateToFibViewCommand}" Padding="16" Margin="4" ToolTip="Switch to FIB mode">
                <Button.Content>
                    <StackPanel Orientation="Vertical">
                        <Image Source="{StaticResource icon_ion}" Height="64"/>
                        <Label Content="FIB" HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Command="{Binding NavigateToLmViewCommand}" Padding="16" Margin="4" ToolTip="Switch to LM mode">
                <Button.Content>
                    <StackPanel Orientation="Vertical">
                        <Image Source="{StaticResource light_bulb_white}" Height="64"/>
                        <Label Content="LM"  HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Command="{Binding NavigateToConfocalViewCommand}" Padding="16" Margin="4" ToolTip="Switch to Confocal mode" Visibility="{Binding ConfocalModeEnabled, Converter={StaticResource BoolVisibilityCollapsedConverter}}">
                <Button.Content>
                    <StackPanel Orientation="Vertical">
                        <Image Source="{StaticResource icon_confocal1_white}" Height="64"/>
                        <Label Content="CONFOCAL"  HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</appControls:ApplicationModeControlBase>
