<UserControl x:Class="Tarmi.App.Views.Modes.ZStackGrabbingUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tarmi.App.Views.Modes"
             xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.Modes"
             xmlns:controls="clr-namespace:Tarmi.App.Controls"
             xmlns:converters="clr-namespace:Tarmi.App.Converters"
             xmlns:localControls ="clr-namespace:Tarmi.App.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance Type=viewModels:ZStackGrabbingViewModel, IsDesignTimeCreatable=False}">
    <StackPanel Margin="0,4,0,0">
        <StackPanel.Resources>
            <converters:EqualityConverter x:Key="EqualityConverter"/>
        </StackPanel.Resources>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <!-- Order of the parameters has to be in the order Minimum - Maximum - UpperValue - LowerValue - Value -->
                <localControls:ZStackSlider Minimum="{Binding ZLimits.Min.Micrometers}" Maximum="{Binding ZLimits.Max.Micrometers}"
                                            UpperValue="{Binding StartPositionInMicrometers}" LowerValue="{Binding EndPositionInMicrometers}"
                                            Value="{Binding LinearStagePosition.Micrometers}" Height="250" ToolTip="Micrometers"/>
            </StackPanel> 
            
            <StackPanel Grid.Column="1">
                <TextBlock Text="Begin [µm]" Margin="0 0 0 5"/>
                <controls:SpinBox Value="{Binding StartPositionInMicrometers}" SmallChange="{Binding StepInMicrometers}"
                                  Minimum="{Binding ZLimits.Min.Micrometers}" Maximum="{Binding ZLimits.Max.Micrometers}"/>
                <Button Grid.Row="1" Width="Auto" Margin="0 5" Command="{Binding UseCurrentPositionAsStartPositionCommand}" ToolTip="Set to current position">
                    <ContentPresenter>
                        <ContentPresenter.ContentTemplate>
                            <DataTemplate>
                                <Image Source="{StaticResource icon_copy}" Width="12" Height="12" Margin="0"/>
                            </DataTemplate>
                        </ContentPresenter.ContentTemplate>
                    </ContentPresenter>
                </Button>
                <TextBlock Text="End [µm]" Margin="0 0 0 5"/>
                <controls:SpinBox Value="{Binding EndPositionInMicrometers}" SmallChange="{Binding StepInMicrometers}"
                                  Minimum="{Binding ZLimits.Min.Micrometers}" Maximum="{Binding ZLimits.Max.Micrometers}"/>
                <Button Grid.Row="1" Width="Auto" Margin="0 5" Command="{Binding UseCurrentPositionAsEndPositionCommand}" ToolTip="Set to current position">
                    <ContentPresenter>
                        <ContentPresenter.ContentTemplate>
                            <DataTemplate>
                                <Image Source="{StaticResource icon_copy}" Width="12" Height="12" Margin="0"/>
                            </DataTemplate>
                        </ContentPresenter.ContentTemplate>
                    </ContentPresenter>
                </Button>
                <TextBlock Text="Current position [µm]" Margin="0 0 0 5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
                    <TextBlock Text="{Binding LinearStagePosition.Micrometers, StringFormat={}{0:F0}}" VerticalAlignment="Center" Margin="0, 5, 5, 0"/>
                    <Button Command="{Binding CopyCurrentPositionToClipboardCommand}" ToolTip="Copy current position to clipboard">
                        <ContentPresenter>
                            <ContentPresenter.ContentTemplate>
                                <DataTemplate>
                                    <Image Source="{StaticResource icon_copy}" Width="12" Height="12" Margin="0"/>
                                </DataTemplate>
                            </ContentPresenter.ContentTemplate>
                        </ContentPresenter>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Separator Margin="0"/>
        <UniformGrid Columns="2">

            <RadioButton x:Name="StepsRadioButton" VerticalAlignment="Center" Content="Number of steps"
                        IsChecked="{Binding ZStackStepSetting, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ZStackStepSetting.VariableNumberOfSteps}, Mode=OneWay}"
                        Command="{Binding SelectStepSettingCommand}" CommandParameter="{x:Static viewModels:ZStackStepSetting.VariableNumberOfSteps}"/>
            <controls:SpinBox Grid.Column="1" Margin="0 5"
                    IsEnabled="{Binding Path=IsChecked, ElementName=StepsRadioButton}"
                    Value="{Binding NumberOfSteps}" SmallChange="1" Minimum="1" Maximum="100"/>
            <RadioButton Grid.Row="1" x:Name="StepSizeRadioButton" VerticalAlignment="Center" Content="Z-step size"
                        IsChecked="{Binding ZStackStepSetting, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ZStackStepSetting.VariableStepSize}, Mode=OneWay}"
                        Command="{Binding SelectStepSettingCommand}" CommandParameter="{x:Static viewModels:ZStackStepSetting.VariableStepSize}"/>
            <TextBox Grid.Column="1" Grid.Row="1" Margin="0 5"
                    IsEnabled="{Binding Path=IsChecked, ElementName=StepSizeRadioButton}"
                    Text="{Binding StepSizeInMicrometers}" HorizontalContentAlignment="Center" ToolTip="Micrometers"/>
        </UniformGrid>
        <Separator Margin="0"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Text="Travel range:"/>
            <TextBlock Grid.Column="1">
                <Run Text="{Binding RangeInMicrometers, StringFormat=N2, Mode=OneWay}"/>
                <Run Text="µm"/>
            </TextBlock>
            <Button Grid.Row="1" Grid.ColumnSpan="2" Margin="0 16 0 0"
                    Content="ACQUIRE Z-STACK" Command="{Binding AcquireZStackCommand}"/>
        </Grid>
    </StackPanel>
</UserControl>
