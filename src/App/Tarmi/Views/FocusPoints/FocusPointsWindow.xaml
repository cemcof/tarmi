<bwpf:DarkWindow x:Class="Tarmi.App.Views.FocusPoints.FocusPointsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:bwpf="clr-namespace:Tarmi.WPF;assembly=Tarmi.WPF"
                 x:TypeArguments="viewModels:FocusPointsWindowViewModel"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Tarmi.App.Views.FocusPoints"
                 xmlns:viewModels="clr-namespace:Tarmi.App.ViewModels.FocusPoints"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=viewModels:FocusPointsWindowViewModel}"
                 AllowsTransparency="True"
                 Background="Transparent"
                 WindowStyle="None"
                 Title="FocusPointsWindow" Height="300" Width="700"
                 WindowStartupLocation="CenterScreen">
    <Border Background="{StaticResource BackgroundDarkBrush}" BorderBrush="{StaticResource ForegroundDarkBrush}" BorderThickness="1" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Background="{StaticResource BackgroundLightBrush}">
                <TextBlock Text="Focus map" FontSize="18" Margin="15,15,0,10" Foreground="{StaticResource ForegroundLightBrush}"/>
                <Button HorizontalAlignment="Right" Margin="15" Width="Auto" Click="CloseButton_Click" Cursor="Hand" ToolTip="Close">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </ControlTemplate>
                    </Button.Template>
                    <Image Source="{StaticResource button_icon_plus}" Width="20">
                        <Image.RenderTransform>
                            <RotateTransform CenterX="10" CenterY="10" Angle="45" />
                        </Image.RenderTransform>
                    </Image>
                </Button>
            </Grid>
            <HeaderedItemsControl Name="FocusPointsControl" ItemsSource="{Binding FocusPoints}" Grid.Row="1"  VerticalAlignment="Top">
                <HeaderedItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" ScrollViewer.VerticalScrollBarVisibility="Visible"/>
                    </ItemsPanelTemplate>
                </HeaderedItemsControl.ItemsPanel>
                <HeaderedItemsControl.Resources>
                    <Style TargetType="{x:Type TextBlock}" x:Key="CenteredElement">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </HeaderedItemsControl.Resources>
                <HeaderedItemsControl.Template>
                    <ControlTemplate TargetType="{x:Type HeaderedItemsControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <ContentPresenter ContentSource="Header"/>
                            <ScrollViewer Grid.Row="2">
                                <Border BorderBrush="{StaticResource ForegroundDarkBrush}" BorderThickness="0 1">
                                    <ItemsPresenter/>
                                </Border>
                            </ScrollViewer>                            
                        </Grid>
                    </ControlTemplate>
                </HeaderedItemsControl.Template>
                <HeaderedItemsControl.HeaderTemplate>
                    <DataTemplate>
                        <Grid Margin="0,10">
                            <Grid.Resources>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredElement}"/>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Margin="10,5"
                                      IsChecked="{Binding DataContext.AreAllFocusPointsSelected, Mode=OneWay, RelativeSource={RelativeSource AncestorType=HeaderedItemsControl}}"
                                      Command="{Binding DataContext.SwitchAllFocusPointsSelectionCommand, RelativeSource={RelativeSource AncestorType=HeaderedItemsControl}}"/>
                            <TextBlock Grid.Column="1" Text="X"/>
                            <TextBlock Grid.Column="2" Text="Y"/>
                            <TextBlock Grid.Column="3" Text="WD/Pos."/>
                        </Grid>
                    </DataTemplate>
                </HeaderedItemsControl.HeaderTemplate>
                <HeaderedItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid IsHitTestVisible="True" VerticalAlignment="Top">
                            <Grid.Resources>
                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CenteredElement}"/>
                            </Grid.Resources>
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HighlightMutedBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Margin="10,5" IsChecked="{Binding IsSelected, Mode=OneWay}"
                                      Command="{Binding DataContext.SwitchFocusPointSelectionCommand, RelativeSource={RelativeSource AncestorType=HeaderedItemsControl}}"
                                      CommandParameter="{Binding .}"/>
                            <TextBlock Grid.Column="1" Text="{Binding X.Millimeters, StringFormat={}{0} mm}" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding Y.Millimeters, StringFormat={}{0} mm}" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Text="{Binding Z.Micrometers, StringFormat={}{0} μm, FallbackValue=''}" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="5" Width="Auto" Height="18" Margin="5,0"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=HeaderedItemsControl}, Path=DataContext.RemoveFocusPointCommand}"
                                    CommandParameter="{Binding .}" ToolTip="Delete">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <ContentPresenter Content="{TemplateBinding Content}"/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Image Source="{StaticResource icon_trash}"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </HeaderedItemsControl.ItemTemplate>
            </HeaderedItemsControl>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="10" HorizontalAlignment="Right" Content="REMOVE SELECTED" Command="{Binding RemoveSelectedFocusPointsCommand}"/>
                <Button Margin="10" HorizontalAlignment="Right" Content="REMOVE ALL" Command="{Binding RemoveAllFocusPointsCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</bwpf:DarkWindow>
