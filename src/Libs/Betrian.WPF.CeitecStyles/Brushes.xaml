<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
>

    <Color x:Key="BackgroundColor">#252f38</Color>
    <Color x:Key="BackgroundDarkColor">#13191f</Color>
    <Color x:Key="BackgroundLightColor">#323f4b</Color>

    <Color x:Key="ForegroundColor">#9aa5b1</Color>
    <Color x:Key="ForegroundDarkColor">#455368</Color>
    <Color x:Key="ForegroundLightColor">#ffffff</Color>

    <Color x:Key="HighlightColor">#b5efa3</Color>
    <Color x:Key="HighlightMutedColor">#4d655e</Color>

    <Color x:Key="Gray10">#1a1a1a</Color>
    <Color x:Key="Gray20">#333333</Color>
    <Color x:Key="Gray30">#4d4d4d</Color>
    <Color x:Key="Gray40">#666666</Color>
    <Color x:Key="Gray50">#808080</Color>
    <Color x:Key="Gray60">#999999</Color>
    <Color x:Key="Gray70">#b3b3b3</Color>
    <Color x:Key="Gray80">#cccccc</Color>
    <Color x:Key="Gray90">#e6e6e6</Color>

    <Color x:Key="ReflectionBlue">#0088ff</Color>
    <Color x:Key="ReflectionGreen">#6fff00</Color>
    <Color x:Key="ReflectionRed">#d83838</Color>
    <Color x:Key="ReflectionUltraviolet">#bb0eaf</Color>

    <Color x:Key="FluorescenceBlue">#6fff00</Color>
    <Color x:Key="FluorescenceGreen">#d83838</Color>
    <Color x:Key="FluorescenceRed">#bb0eaf</Color>
    <Color x:Key="FluorescenceUltraviolet">#0088ff</Color>

    <Color x:Key="SuccessBackground">#314d1a</Color>
    <Color x:Key="WarningBackground">#644a24</Color>
    <Color x:Key="ErrorBackground">#5e1718</Color>
    <Color x:Key="InfoBackground">#003a66</Color>

    <Color x:Key="SuccessForeground">#7ac143</Color>
    <Color x:Key="WarningForeground">#f9b959</Color>
    <Color x:Key="ErrorForeground">#ea3a3d</Color>
    <Color x:Key="InfoForeground">#0090ff</Color>

    <Color x:Key="YellowForeground">#FFEDFF00</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDarkColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource BackgroundLightColor}" options:Freeze="True" />

    <SolidColorBrush x:Key="ForegroundBrush" Color="{StaticResource ForegroundColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="ForegroundDarkBrush" Color="{StaticResource ForegroundDarkColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="ForegroundLightBrush" Color="{StaticResource ForegroundLightColor}" options:Freeze="True" />

    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}" options:Freeze="True" />
    <SolidColorBrush x:Key="HighlightMutedBrush" Color="{StaticResource HighlightMutedColor}" options:Freeze="True" />

    <SolidColorBrush x:Key="Gray10Brush" Color="{StaticResource Gray10}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray20Brush" Color="{StaticResource Gray20}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray30Brush" Color="{StaticResource Gray30}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray40Brush" Color="{StaticResource Gray40}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray50Brush" Color="{StaticResource Gray50}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray60Brush" Color="{StaticResource Gray60}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray70Brush" Color="{StaticResource Gray70}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray80Brush" Color="{StaticResource Gray80}" options:Freeze="True" />
    <SolidColorBrush x:Key="Gray90Brush" Color="{StaticResource Gray90}" options:Freeze="True" />


    <SolidColorBrush x:Key="FluorescenceBlueBrush" Color="{StaticResource FluorescenceBlue}" options:Freeze="True" />
    <SolidColorBrush x:Key="FluorescenceGreenBrush" Color="{StaticResource FluorescenceGreen}" options:Freeze="True" />
    <SolidColorBrush x:Key="FluorescenceRedBrush" Color="{StaticResource FluorescenceRed}" options:Freeze="True" />
    <SolidColorBrush x:Key="FluorescenceUltravioletBrush" Color="{StaticResource FluorescenceUltraviolet}" options:Freeze="True" />

    <SolidColorBrush x:Key="ReflectionBlueBrush" Color="{StaticResource ReflectionBlue}" options:Freeze="True" />
    <SolidColorBrush x:Key="ReflectionGreenBrush" Color="{StaticResource ReflectionGreen}" options:Freeze="True" />
    <SolidColorBrush x:Key="ReflectionRedBrush" Color="{StaticResource ReflectionRed}" options:Freeze="True" />
    <SolidColorBrush x:Key="ReflectionUltravioletBrush" Color="{StaticResource ReflectionUltraviolet}" options:Freeze="True" />

    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{StaticResource SuccessBackground}" options:Freeze="True" />
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{StaticResource WarningBackground}" options:Freeze="True" />
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{StaticResource ErrorBackground}" options:Freeze="True" />
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="{StaticResource InfoBackground}" options:Freeze="True" />
    
    <SolidColorBrush x:Key="SuccessForegroundBrush" Color="{StaticResource SuccessForeground}" options:Freeze="True" />
    <SolidColorBrush x:Key="WarningForegroundBrush" Color="{StaticResource WarningForeground}" options:Freeze="True" />
    <SolidColorBrush x:Key="ErrorForegroundBrush" Color="{StaticResource ErrorForeground}" options:Freeze="True" />
    <SolidColorBrush x:Key="InfoForegroundBrush" Color="{StaticResource InfoForeground}" options:Freeze="True" />

    <SolidColorBrush x:Key="YellowForegroundBrush" Color="{StaticResource YellowForeground}" options:Freeze="True" />
</ResourceDictionary>
